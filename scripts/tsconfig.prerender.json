{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "types": ["node"],
    "paths": {
      "framer-motion": ["src/prerender/mocks/framer-motion.tsx"]
    }
  },
  "include": ["../src/**/*.ts", "../src/**/*.tsx", "./**/*.ts"]
}
