# ─── GBP Audit environment ─── copy to .env and fill in. Never commit .env.

# AI roadmap generation (Lever 1) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Roadmap PDF email delivery (Lever 3) — https://resend.com
RESEND_API_KEY=
GBP_ROADMAP_FROM_EMAIL=Stratezik <reports@stratezik.com>

# Unified Google Sheets router webhook for ALL lead types (google-apps-script-router.js).
# The site sends a `type` field and this one URL routes to the right tab.
GOOGLE_LEADS_WEBHOOK_URL=
# Legacy per-product webhook (only used as a fallback if GOOGLE_LEADS_WEBHOOK_URL is unset)
GOOGLE_GBP_LEADS_WEBHOOK_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_PLACES_API_KEY=
GBP_DETAIL_COMPETITORS=3
STRIPE_SECRET_KEY=
GBP_ROADMAP_PRICE_CENTS=2900
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Paid order failure monitoring ───
# Stripe webhook signing secret (Dashboard → Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=
# Apps Script /exec URL for the "Paid Order Issues" sheet tab
GOOGLE_PAID_ISSUES_WEBHOOK_URL=
# Optional: override the alert recipient / sender (defaults shown)
PAID_ISSUES_EMAIL=stratezikdigital@gmail.com
PAID_ISSUES_FROM_EMAIL=Stratezik <reports@stratezik.com>
# Protects the /api/reconcile-orders cron endpoint (set the same value in Vercel)
CRON_SECRET=
