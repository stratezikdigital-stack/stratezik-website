    "check:blog-author": "node ./node_modules/tsx/dist/cli.mjs scripts/check-blog-author.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "seo:postbuild": "node ./node_modules/tsx/dist/cli.mjs scripts/postbuild-seo.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
